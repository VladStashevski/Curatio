<Window
    x:Class="Curatio.Desktop.MainWindow"
    x:DataType="local:MainWindowViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:Curatio.Core"
    xmlns:local="using:Curatio.Desktop"
    Title="Curatio"
    Width="1320"
    Height="760"
    MinWidth="760"
    MinHeight="480"
    FontFamily="avares://Avalonia.Fonts.Inter/Assets#Inter"
    FontSize="13"
    Foreground="{StaticResource BrushForeground}"
    Background="{StaticResource BrushBackground}">
  <Window.Resources>
    <local:DocumentStatusConverter x:Key="StatusConverter" />
    <local:DocumentStatusColorConverter x:Key="StatusColorConverter" />
    <ControlTheme x:Key="CenteredDataGridCell"
                  TargetType="DataGridCell"
                  BasedOn="{StaticResource {x:Type DataGridCell}}">
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </ControlTheme>
  </Window.Resources>

  <LayoutTransformControl>
    <LayoutTransformControl.LayoutTransform>
      <ScaleTransform ScaleX="{Binding UiScale}" ScaleY="{Binding UiScale}" />
    </LayoutTransformControl.LayoutTransform>

    <Grid RowDefinitions="57,*">
      <Border Grid.Row="0" Classes="header" Padding="20,0">
        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
          <TextBlock Classes="title"
                     Text="Curatio"
                     VerticalAlignment="Center" />

          <TextBlock Grid.Column="1"
                     Classes="muted"
                     Text="{Binding Notification}"
                     TextTrimming="CharacterEllipsis"
                     VerticalAlignment="Center" />

          <StackPanel Grid.Column="2"
                      Orientation="Horizontal"
                      Spacing="8"
                      VerticalAlignment="Center">
            <local:LoadingSpinner Width="18"
                                  Height="18"
                                  Margin="0,0,4,0"
                                  IsVisible="{Binding IsBusy}" />
            <Button Classes="secondary compact"
                    Command="{Binding ChooseFolderCommand}"
                    Content="Папка"
                    ToolTip.Tip="{Binding SelectedFolder}" />
            <Button Classes="primary compact"
                    Command="{Binding ScanCommand}"
                    Content="Анализировать" />
            <Button Classes="secondary compact"
                    Command="{Binding ClearRecordsCommand}"
                    Content="Очистить"
                    ToolTip.Tip="Удалить все извлечённые записи из локальной базы" />
            <Button Classes="secondary compact" Content="Вид">
              <Button.Flyout>
                <Flyout Placement="BottomEdgeAlignedRight">
                  <StackPanel Width="220" Spacing="12" Margin="4">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="Масштаб"
                                 FontWeight="SemiBold"
                                 VerticalAlignment="Center" />
                      <TextBlock Grid.Column="1"
                                 Classes="muted"
                                 Text="{Binding UiScaleText}"
                                 VerticalAlignment="Center" />
                    </Grid>
                    <Slider Minimum="0.8"
                            Maximum="1.25"
                            TickFrequency="0.05"
                            IsSnapToTickEnabled="True"
                            Value="{Binding UiScale, Mode=TwoWay}" />
                    <Border Height="1" Background="{StaticResource BrushBorder}" />
                    <TextBlock Text="Колонки" FontWeight="SemiBold" />
                    <ItemsControl ItemsSource="{Binding TableColumns}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:TableColumnPreference">
                          <CheckBox Content="{Binding Title}"
                                    IsChecked="{Binding IsVisible, Mode=TwoWay}"
                                    Margin="0,3" />
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Classes="ghost compact"
                            HorizontalAlignment="Stretch"
                            Command="{Binding ResetViewCommand}"
                            Content="Сбросить вид" />
                  </StackPanel>
                </Flyout>
              </Button.Flyout>
            </Button>
            <Button Classes="secondary compact"
                    Command="{Binding ExportCsvCommand}"
                    Content="CSV" />
            <Button Classes="secondary compact"
                    Command="{Binding ExportXlsxCommand}"
                    Content="Экспорт" />
          </StackPanel>
        </Grid>
      </Border>

      <Grid Grid.Row="1" Margin="8,0,8,8">
        <Border Classes="tableCard">
          <DataGrid x:Name="ResultsGrid"
                    ItemsSource="{Binding Records}"
                    SelectedItem="{Binding SelectedRecord}"
                    AutoGenerateColumns="False"
                    IsReadOnly="False"
                    CanUserReorderColumns="True"
                    CanUserResizeColumns="True"
                    MinColumnWidth="110"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto"
                    GridLinesVisibility="All"
                    HorizontalGridLinesBrush="{StaticResource BrushBorder}"
                    VerticalGridLinesBrush="{StaticResource BrushBorder}"
                    BorderThickness="0"
                    RowEditEnded="OnRowEditEnded">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Заключение"
                                  Tag="claim"
                                  CellTheme="{StaticResource CenteredDataGridCell}"
                                  Binding="{ReflectionBinding ClaimNumber, Mode=TwoWay}"
                                  Width="170" />
              <DataGridTextColumn Header="Дата заключения"
                                  Tag="date"
                                  CellTheme="{StaticResource CenteredDataGridCell}"
                                  Binding="{ReflectionBinding EventDateText, Mode=TwoWay}"
                                  Width="145" />
              <DataGridTextColumn Header="Полис"
                                  Tag="policy"
                                  CellTheme="{StaticResource CenteredDataGridCell}"
                                  Binding="{ReflectionBinding PolicyNumber, Mode=TwoWay}"
                                  Width="190" />
              <DataGridTextColumn Header="Меддокумент"
                                  Tag="medicalDocument"
                                  CellTheme="{StaticResource CenteredDataGridCell}"
                                  Binding="{ReflectionBinding MedicalDocumentNumber, Mode=TwoWay}"
                                  Width="155" />
              <DataGridTextColumn Header="Эксперт"
                                  Tag="expert"
                                  Binding="{ReflectionBinding ExpertName, Mode=TwoWay}"
                                  Width="240" />
              <DataGridTextColumn Header="Специальность"
                                  Tag="expertSpecialty"
                                  Binding="{ReflectionBinding ExpertSpecialty, Mode=TwoWay}"
                                  Width="210" />
              <DataGridTextColumn Header="Форма помощи"
                                  Tag="careForm"
                                  CellTheme="{StaticResource CenteredDataGridCell}"
                                  Binding="{ReflectionBinding CareForm, Mode=TwoWay}"
                                  Width="155" />
              <DataGridTextColumn Header="Период помощи"
                                  Tag="carePeriod"
                                  CellTheme="{StaticResource CenteredDataGridCell}"
                                  Binding="{ReflectionBinding CarePeriod, Mode=TwoWay}"
                                  Width="210" />
              <DataGridTextColumn Header="Основной диагноз"
                                  Tag="diagnosis"
                                  Binding="{ReflectionBinding PrimaryDiagnosis, Mode=TwoWay}"
                                  Width="360" />
              <DataGridTextColumn Header="Осложнение"
                                  Tag="diagnosisComplication"
                                  Binding="{ReflectionBinding DiagnosisComplication, Mode=TwoWay}"
                                  Width="300" />
              <DataGridTextColumn Header="Сопутствующие диагнозы"
                                  Tag="comorbidDiagnosis"
                                  Binding="{ReflectionBinding ComorbidDiagnosis, Mode=TwoWay}"
                                  Width="420" />
              <DataGridTextColumn Header="Операция"
                                  Tag="operation"
                                  CellTheme="{StaticResource CenteredDataGridCell}"
                                  Binding="{ReflectionBinding Operation, Mode=TwoWay}"
                                  Width="240" />
              <DataGridTextColumn Header="КСГ"
                                  Tag="clinicalStatisticalGroup"
                                  CellTheme="{StaticResource CenteredDataGridCell}"
                                  Binding="{ReflectionBinding ClinicalStatisticalGroup, Mode=TwoWay}"
                                  Width="340" />
              <DataGridTextColumn Header="Код дефекта"
                                  Tag="defectCode"
                                  CellTheme="{StaticResource CenteredDataGridCell}"
                                  Binding="{ReflectionBinding DefectCode, Mode=TwoWay}"
                                  Width="125" />
              <DataGridTextColumn Header="Дефект"
                                  Tag="defect"
                                  Binding="{ReflectionBinding DefectDescription, Mode=TwoWay}"
                                  Width="420" />
              <DataGridTextColumn Header="Выводы"
                                  Tag="description"
                                  Binding="{ReflectionBinding EventDescription, Mode=TwoWay}"
                                  Width="380" />
              <DataGridTextColumn Header="Файл"
                                  Tag="file"
                                  Binding="{ReflectionBinding SourceFileName}"
                                  IsReadOnly="True"
                                  Width="280" />
              <DataGridTemplateColumn Header="Статус"
                                      Tag="status"
                                      CellTheme="{StaticResource CenteredDataGridCell}"
                                      IsReadOnly="True"
                                      Width="140">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate x:DataType="core:InsuranceRecord">
                    <Border Background="{Binding Status, Converter={StaticResource StatusColorConverter}, ConverterParameter=bg}"
                            CornerRadius="999"
                            Padding="9,3"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                      <TextBlock Text="{Binding Status, Converter={StaticResource StatusConverter}}"
                                 Foreground="{Binding Status, Converter={StaticResource StatusColorConverter}, ConverterParameter=fg}"
                                 FontSize="12"
                                 FontWeight="Medium" />
                    </Border>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="Застрахованный"
                                  Tag="client"
                                  Binding="{ReflectionBinding ClientFullName, Mode=TwoWay}"
                                  Width="240" />
              <DataGridTextColumn Header="Пол"
                                  Tag="gender"
                                  CellTheme="{StaticResource CenteredDataGridCell}"
                                  Binding="{ReflectionBinding Gender, Mode=TwoWay}"
                                  Width="110" />
              <DataGridTextColumn Header="Дата рождения"
                                  Tag="birthDate"
                                  CellTheme="{StaticResource CenteredDataGridCell}"
                                  Binding="{ReflectionBinding BirthDateText, Mode=TwoWay}"
                                  Width="140" />
              <DataGridTextColumn Header="Страховая организация"
                                  Tag="insuranceOrganization"
                                  Binding="{ReflectionBinding InsuranceOrganization, Mode=TwoWay}"
                                  Width="340" />
              <DataGridTextColumn Header="Медицинская организация"
                                  Tag="medicalOrganization"
                                  Binding="{ReflectionBinding MedicalOrganization, Mode=TwoWay}"
                                  Width="360" />
              <DataGridTextColumn Header="Вид проверки"
                                  Tag="checkType"
                                  CellTheme="{StaticResource CenteredDataGridCell}"
                                  Binding="{ReflectionBinding CheckType, Mode=TwoWay}"
                                  Width="150" />
              <DataGridTextColumn Header="Форма экспертизы"
                                  Tag="examinationForm"
                                  CellTheme="{StaticResource CenteredDataGridCell}"
                                  Binding="{ReflectionBinding ExaminationForm, Mode=TwoWay}"
                                  Width="190" />
              <DataGridTextColumn Header="Срок экспертизы"
                                  Tag="examinationPeriod"
                                  CellTheme="{StaticResource CenteredDataGridCell}"
                                  Binding="{ReflectionBinding ExaminationPeriod, Mode=TwoWay}"
                                  Width="210" />
              <DataGridTextColumn Header="Условия помощи"
                                  Tag="careConditions"
                                  CellTheme="{StaticResource CenteredDataGridCell}"
                                  Binding="{ReflectionBinding CareConditions, Mode=TwoWay}"
                                  Width="170" />
              <DataGridTextColumn Header="Профиль помощи"
                                  Tag="careProfile"
                                  CellTheme="{StaticResource CenteredDataGridCell}"
                                  Binding="{ReflectionBinding CareProfile, Mode=TwoWay}"
                                  Width="210" />
              <DataGridTextColumn Header="Исход"
                                  Tag="outcome"
                                  CellTheme="{StaticResource CenteredDataGridCell}"
                                  Binding="{ReflectionBinding CaseOutcome, Mode=TwoWay}"
                                  Width="170" />
              <DataGridTextColumn Header="Рекомендации"
                                  Tag="recommendations"
                                  Binding="{ReflectionBinding Recommendations, Mode=TwoWay}"
                                  Width="380" />
              <DataGridTextColumn Header="Сумма случая"
                                  Tag="amount"
                                  CellTheme="{StaticResource CenteredDataGridCell}"
                                  Binding="{ReflectionBinding InsuredAmountText, Mode=TwoWay}"
                                  Width="140" />
              <DataGridTextColumn Header="Финансовые санкции"
                                  Tag="financialSanctions"
                                  CellTheme="{StaticResource CenteredDataGridCell}"
                                  Binding="{ReflectionBinding FinancialSanctionsAmountText, Mode=TwoWay}"
                                  Width="170" />
              <DataGridTextColumn Header="Неоплата/уменьшение"
                                  Tag="paymentReduction"
                                  CellTheme="{StaticResource CenteredDataGridCell}"
                                  Binding="{ReflectionBinding PaymentReductionAmountText, Mode=TwoWay}"
                                  Width="190" />
              <DataGridTextColumn Header="Штраф"
                                  Tag="penalty"
                                  CellTheme="{StaticResource CenteredDataGridCell}"
                                  Binding="{ReflectionBinding PenaltyAmountText, Mode=TwoWay}"
                                  Width="140" />
            </DataGrid.Columns>
          </DataGrid>
        </Border>

        <Border Background="#D9FFFFFF"
                IsVisible="{Binding IsBusy}">
          <StackPanel HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Spacing="12">
            <local:LoadingSpinner Width="28" Height="28" />
            <TextBlock Classes="muted"
                       Text="{Binding ProgressText}"
                       MaxWidth="420"
                       TextAlignment="Center"
                       TextTrimming="CharacterEllipsis" />
          </StackPanel>
        </Border>
      </Grid>
    </Grid>
  </LayoutTransformControl>
</Window>
