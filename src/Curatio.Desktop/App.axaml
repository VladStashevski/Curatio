<Application
    x:Class="Curatio.Desktop.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedThemeVariant="Light">

  <Application.Resources>
    <ResourceDictionary>
      <!-- Minimal neutral palette -->
      <SolidColorBrush x:Key="BrushBackground" Color="#FAFAFA" />
      <SolidColorBrush x:Key="BrushSurface" Color="#FFFFFF" />
      <SolidColorBrush x:Key="BrushForeground" Color="#09090B" />
      <SolidColorBrush x:Key="BrushMuted" Color="#71717A" />
      <SolidColorBrush x:Key="BrushSubtle" Color="#F4F4F5" />
      <SolidColorBrush x:Key="BrushBorder" Color="#E4E4E7" />
      <SolidColorBrush x:Key="BrushBorderStrong" Color="#D4D4D8" />
      <SolidColorBrush x:Key="BrushPrimary" Color="#18181B" />
      <SolidColorBrush x:Key="BrushPrimaryHover" Color="#27272A" />
      <SolidColorBrush x:Key="BrushPrimaryPressed" Color="#09090B" />
      <SolidColorBrush x:Key="BrushPrimaryForeground" Color="#FFFFFF" />
      <SolidColorBrush x:Key="BrushPrimarySoft" Color="#F4F4F5" />
      <SolidColorBrush x:Key="BrushDestructive" Color="#DC2626" />
      <SolidColorBrush x:Key="BrushRing" Color="#18181B" />

      <Color x:Key="SystemAccentColor">#18181B</Color>
      <Color x:Key="SystemAccentColorLight1">#27272A</Color>
      <Color x:Key="SystemAccentColorLight2">#3F3F46</Color>
      <Color x:Key="SystemAccentColorLight3">#52525B</Color>
      <Color x:Key="SystemAccentColorDark1">#18181B</Color>
      <Color x:Key="SystemAccentColorDark2">#09090B</Color>
      <Color x:Key="SystemAccentColorDark3">#000000</Color>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />

    <!-- ===== Типографика ===== -->
    <Style Selector="TextBlock.title">
      <Setter Property="FontSize" Value="17" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource BrushForeground}" />
    </Style>
    <Style Selector="TextBlock.cardTitle">
      <Setter Property="FontSize" Value="15" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource BrushForeground}" />
    </Style>
    <Style Selector="TextBlock.label">
      <Setter Property="FontSize" Value="12.5" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Foreground" Value="{StaticResource BrushMuted}" />
    </Style>
    <Style Selector="TextBlock.muted">
      <Setter Property="Foreground" Value="{StaticResource BrushMuted}" />
    </Style>

    <!-- ===== Карточка ===== -->
    <Style Selector="Border.card">
      <Setter Property="Background" Value="{StaticResource BrushSurface}" />
      <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="14" />
      <!-- мягкая двойная тень: контактная + ambient -->
      <Setter Property="BoxShadow" Value="0 1 2 0 #0D18181B, 0 12 32 -12 #1418181B" />
    </Style>
    <Style Selector="Border.tableCard">
      <Setter Property="Background" Value="{StaticResource BrushSurface}" />
      <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="ClipToBounds" Value="True" />
      <Setter Property="BoxShadow" Value="0 1 2 0 #0D18181B" />
    </Style>
    <Style Selector="Border.header">
      <Setter Property="Background" Value="{StaticResource BrushSurface}" />
      <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="BoxShadow" Value="0 1 3 0 #0A18181B" />
    </Style>
    <Style Selector="Border.formFooter">
      <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
      <Setter Property="BorderThickness" Value="0,1,0,0" />
    </Style>

    <!-- ===== Кнопки ===== -->
    <Style Selector="Button">
      <Setter Property="Background" Value="{StaticResource BrushSurface}" />
      <Setter Property="Foreground" Value="{StaticResource BrushForeground}" />
      <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="Padding" Value="15,9" />
      <Setter Property="MinHeight" Value="38" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="RenderTransform" Value="none" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.18" Easing="CubicEaseOut" />
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.13" Easing="CubicEaseOut" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button:pressed">
      <Setter Property="RenderTransform" Value="scale(0.97)" />
    </Style>
    <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{StaticResource BrushSubtle}" />
      <Setter Property="BorderBrush" Value="{StaticResource BrushBorderStrong}" />
      <Setter Property="TextElement.Foreground" Value="{StaticResource BrushForeground}" />
    </Style>
    <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{StaticResource BrushBorder}" />
    </Style>
    <Style Selector="Button:disabled">
      <Setter Property="Opacity" Value="0.5" />
    </Style>
    <Style Selector="Button /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.18" Easing="CubicEaseOut" />
          <BrushTransition Property="BorderBrush" Duration="0:0:0.18" Easing="CubicEaseOut" />
        </Transitions>
      </Setter>
    </Style>

    <!-- Primary -->
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{StaticResource BrushPrimary}" />
      <Setter Property="Foreground" Value="{StaticResource BrushPrimaryForeground}" />
      <Setter Property="BorderBrush" Value="{StaticResource BrushPrimary}" />
    </Style>
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{StaticResource BrushPrimaryHover}" />
      <Setter Property="BorderBrush" Value="{StaticResource BrushPrimaryHover}" />
      <Setter Property="TextElement.Foreground" Value="{StaticResource BrushPrimaryForeground}" />
    </Style>
    <Style Selector="Button.primary:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{StaticResource BrushPrimaryPressed}" />
      <Setter Property="BorderBrush" Value="{StaticResource BrushPrimaryPressed}" />
    </Style>
    <Style Selector="Button.primary:disabled /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{StaticResource BrushPrimary}" />
      <Setter Property="BorderBrush" Value="{StaticResource BrushPrimary}" />
      <Setter Property="TextElement.Foreground" Value="{StaticResource BrushPrimaryForeground}" />
    </Style>

    <!-- Secondary (= нейтральная по умолчанию, явный класс для читаемости) -->
    <Style Selector="Button.secondary">
      <Setter Property="Background" Value="{StaticResource BrushSurface}" />
      <Setter Property="Foreground" Value="{StaticResource BrushForeground}" />
      <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
    </Style>

    <!-- Destructive -->
    <Style Selector="Button.destructive">
      <Setter Property="Background" Value="{StaticResource BrushDestructive}" />
      <Setter Property="Foreground" Value="{StaticResource BrushPrimaryForeground}" />
      <Setter Property="BorderBrush" Value="{StaticResource BrushDestructive}" />
    </Style>
    <Style Selector="Button.destructive:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#B91C1C" />
      <Setter Property="BorderBrush" Value="#B91C1C" />
      <Setter Property="TextElement.Foreground" Value="{StaticResource BrushPrimaryForeground}" />
    </Style>
    <Style Selector="Button.destructive:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#991B1B" />
      <Setter Property="BorderBrush" Value="#991B1B" />
    </Style>

    <!-- Ghost -->
    <Style Selector="Button.ghost">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{StaticResource BrushMuted}" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="Button.ghost:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{StaticResource BrushSubtle}" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="TextElement.Foreground" Value="{StaticResource BrushForeground}" />
    </Style>
    <Style Selector="Button.compact">
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- ===== Поля ввода ===== -->
    <Style Selector="TextBox">
      <Setter Property="Background" Value="{StaticResource BrushSurface}" />
      <Setter Property="Foreground" Value="{StaticResource BrushForeground}" />
      <Setter Property="BorderBrush" Value="{StaticResource BrushBorderStrong}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="11,8" />
      <Setter Property="MinHeight" Value="38" />
      <Setter Property="FontSize" Value="14" />
    </Style>
    <Style Selector="TextBox /template/ Border#PART_BorderElement">
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.18" Easing="CubicEaseOut" />
          <BrushTransition Property="Background" Duration="0:0:0.18" Easing="CubicEaseOut" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
      <Setter Property="BorderBrush" Value="{StaticResource BrushBorderStrong}" />
    </Style>
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
      <Setter Property="BorderBrush" Value="{StaticResource BrushRing}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- ===== ComboBox ===== -->
    <Style Selector="ComboBox">
      <Setter Property="Background" Value="{StaticResource BrushSurface}" />
      <Setter Property="Foreground" Value="{StaticResource BrushForeground}" />
      <Setter Property="BorderBrush" Value="{StaticResource BrushBorderStrong}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="11,7" />
      <Setter Property="MinHeight" Value="38" />
      <Setter Property="FontSize" Value="14" />
    </Style>
    <Style Selector="ComboBox /template/ Border#Background">
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.18" Easing="CubicEaseOut" />
          <BrushTransition Property="Background" Duration="0:0:0.18" Easing="CubicEaseOut" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="ComboBox:pointerover /template/ Border#Background">
      <Setter Property="BorderBrush" Value="{StaticResource BrushBorderStrong}" />
    </Style>
    <Style Selector="ComboBoxItem">
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="10,7" />
      <Setter Property="FontSize" Value="14" />
    </Style>
    <Style Selector="ComboBoxItem /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.15" Easing="CubicEaseOut" />
        </Transitions>
      </Setter>
    </Style>

    <!-- ===== CheckBox ===== -->
    <Style Selector="CheckBox">
      <Setter Property="FontSize" Value="14" />
    </Style>
    <Style Selector="CheckBox /template/ Border#NormalRectangle">
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.15" Easing="CubicEaseOut" />
          <BrushTransition Property="BorderBrush" Duration="0:0:0.15" Easing="CubicEaseOut" />
        </Transitions>
      </Setter>
    </Style>

    <!-- ===== ProgressBar ===== -->
    <Style Selector="ProgressBar">
      <Setter Property="Foreground" Value="{StaticResource BrushPrimary}" />
      <Setter Property="Background" Value="{StaticResource BrushSubtle}" />
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="MinHeight" Value="8" />
      <Setter Property="Height" Value="8" />
    </Style>

    <!-- ===== DataGrid ===== -->
    <Style Selector="DataGrid">
      <Setter Property="Background" Value="{StaticResource BrushSurface}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="GridLinesVisibility" Value="Horizontal" />
      <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BrushBorder}" />
      <Setter Property="VerticalGridLinesBrush" Value="{StaticResource BrushBorder}" />
      <Setter Property="RowHeight" Value="44" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="DataGridColumnHeader">
      <Setter Property="Background" Value="{StaticResource BrushSubtle}" />
      <Setter Property="Foreground" Value="{StaticResource BrushMuted}" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="Padding" Value="1.5,0" />
      <Setter Property="MinHeight" Value="40" />
      <Setter Property="SeparatorBrush" Value="{StaticResource BrushBorderStrong}" />
      <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>
    <Style Selector="DataGridColumnHeader TextBlock">
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
      <Setter Property="TextWrapping" Value="NoWrap" />
    </Style>
    <Style Selector="DataGridCell">
      <Setter Property="Foreground" Value="{StaticResource BrushForeground}" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
      <Setter Property="BorderThickness" Value="0,0,1,0" />
    </Style>
    <Style Selector="DataGridCell TextBlock">
      <Setter Property="Margin" Value="1.5,0" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
      <Setter Property="TextWrapping" Value="NoWrap" />
    </Style>
    <Style Selector="DataGridCell TextBox">
      <Setter Property="Padding" Value="1.5,0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="DataGridRow /template/ Rectangle#BackgroundRectangle">
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Fill" Duration="0:0:0.15" Easing="CubicEaseOut" />
          <DoubleTransition Property="Opacity" Duration="0:0:0.15" Easing="CubicEaseOut" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="DataGridRow:pointerover /template/ Rectangle#BackgroundRectangle">
      <Setter Property="Fill" Value="{StaticResource BrushSubtle}" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
      <Setter Property="Fill" Value="{StaticResource BrushPrimarySoft}" />
      <Setter Property="Opacity" Value="1" />
    </Style>

    <!-- ===== ListBox (журнал) ===== -->
    <Style Selector="ListBox">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="ListBoxItem">
      <Setter Property="Padding" Value="6,7" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="CornerRadius" Value="7" />
    </Style>
    <Style Selector="ListBoxItem /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.15" Easing="CubicEaseOut" />
        </Transitions>
      </Setter>
    </Style>

    <!-- ===== ScrollBar (тонкий, приглушённый) ===== -->
    <Style Selector="ScrollBar:vertical">
      <Setter Property="Width" Value="10" />
    </Style>
    <Style Selector="ScrollBar /template/ Thumb">
      <Setter Property="Background" Value="#D4D4D8" />
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.15" Easing="CubicEaseOut" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="ScrollBar /template/ Thumb:pointerover">
      <Setter Property="Background" Value="#A1A1AA" />
    </Style>

    <!-- ===== GridSplitter ===== -->
    <Style Selector="GridSplitter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
  </Application.Styles>
</Application>
